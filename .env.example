# --- Backend ---
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000

# PostgreSQL (yerel) — pgvector extension yüklü olmalı
POSTGRES_USER=academicguide
POSTGRES_PASSWORD=change_me
POSTGRES_DB=academicguide
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DATABASE_URL=postgresql+psycopg://academicguide:change_me@localhost:5432/academicguide

# pgvector koleksiyonu (logical namespace)
VECTOR_COLLECTION=tubitak_2209

# LLM
# LLM_PROVIDER: "ollama" (default, fully local) or "openai"
LLM_PROVIDER=ollama
LLM_TEMPERATURE=0.2

# Ollama (yerel LLM) — `ollama serve` çalıştırmalı, `ollama pull <model>` ile model indirilmiş olmalı
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b-instruct

# OpenAI (sadece LLM_PROVIDER veya EMBEDDING_PROVIDER 'openai' iken kullanılır)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Embeddings
# EMBEDDING_PROVIDER: "huggingface" (default, BGE-M3 local) or "openai"
EMBEDDING_PROVIDER=huggingface
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DEVICE=cpu
EMBEDDING_NORMALIZE=true
HF_CACHE_DIR=./data/hf

# Auth
JWT_SECRET=dev-only-change-me-32-chars-min
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# CORS
CORS_ORIGINS=http://localhost:5173

# --- Frontend ---
VITE_API_BASE_URL=http://localhost:8000
