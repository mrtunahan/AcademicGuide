# --- Backend ---
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000

# PostgreSQL
POSTGRES_USER=academicguide
POSTGRES_PASSWORD=change_me
POSTGRES_DB=academicguide
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+psycopg://academicguide:change_me@postgres:5432/academicguide

# ChromaDB
CHROMA_HOST=chroma
CHROMA_PORT=8001
CHROMA_COLLECTION=tubitak_2209

# LLM
OPENAI_API_KEY=
LLM_MODEL=gpt-4o-mini

# Embeddings
# EMBEDDING_PROVIDER: "huggingface" (default, BGE-M3 local) or "openai"
EMBEDDING_PROVIDER=huggingface
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DEVICE=cpu
EMBEDDING_NORMALIZE=true
HF_CACHE_DIR=/app/data/hf

# CORS
CORS_ORIGINS=http://localhost:5173

# --- Frontend ---
VITE_API_BASE_URL=http://localhost:8000
